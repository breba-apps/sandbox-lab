# Copy entries from this file to .env only when they are not already supplied by
# the process environment. Environment variables take precedence over .env.
#
# If a variable is supplied by a container runtime or proxy, use a harmless
# placeholder in .env only when the app or SDK requires the variable name to
# exist locally.

# Required unless supplied by the runtime.
OPENAI_API_KEY=sk-...

# Optional model used for inference (defaults to gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# Optional OpenAI request timeout in seconds (defaults to 30).
REQUEST_TIMEOUT_SECONDS=30

# Cloudflare R2 (S3-compatible) bucket used to store each inference record.
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=...
