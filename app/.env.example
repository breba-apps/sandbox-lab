# Copy to .env and fill in your values.

# Required: your OpenAI API key.
OPENAI_API_KEY=sk-...

# Optional: the model used for inference (defaults to gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# Optional: OpenAI request timeout in seconds (defaults to 30).
REQUEST_TIMEOUT_SECONDS=30

# Required: Cloudflare R2 (S3-compatible) bucket used to store each inference record.
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=...
